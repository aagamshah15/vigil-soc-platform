POSTGRES_DB=threat_risk
POSTGRES_USER=app
POSTGRES_PASSWORD=app

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=lake

# Optional: deterministic runs (YYYY-MM-DD)
RUN_DATE=2026-01-19

# Phase 5 security and SLO defaults
API_AUTH_ENABLED=false
API_KEY=change-me-local-demo-key
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=120
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8600
MAX_STREAM_LAG_MINUTES=15
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Phase 6 SOC demo defaults
SOC_TOPIC=security.events
SOC_SCENARIO=financial_attack_chain
SOC_EVENT_BATCH_SIZE=200
SOC_MIN_CRITICAL_SCORE=80

# Phase 7A: JWT auth + WebSocket
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_AUTH_ENABLED=false
PRODUCTION_MODE=false
COOKIE_SECURE=false
SEED_DEMO_USERS=true
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
WS_TICKET_TTL_SECONDS=30
# Demo accounts (password = "changeme" for all):
#   l1@soc.internal         - L1 Analyst
#   l2@soc.internal         - L2 Analyst
#   manager@soc.internal    - SOC Manager
#   ciso@soc.internal       - CISO
#   compliance@soc.internal - Compliance Officer

# Phase 8A: live GitHub activity + threat-intel IOC enrichment
# Leave blank for local demo mode, or set real values only in your private .env.
OTX_API_KEY=
INTEL_LOOP_SECONDS=900
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_POLL_SECONDS=60
